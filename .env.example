# =====================================================================
# Copia este archivo a `.env.local` y rellena los valores que necesites.
# `.env.local` está en .gitignore: NUNCA lo commitees.
# =====================================================================

# ---------------------------------------------------------------------
# Event gate (cliente)
# Fecha y hora a partir de la cual la app deja de mostrar la cuenta
# regresiva. Formato ISO-8601 con offset.
# Para desarrollo, abre /?dev=1 en el navegador para bypass temporal.
# ---------------------------------------------------------------------
NEXT_PUBLIC_EVENT_UNLOCK_AT=2026-04-30T00:00:00-04:00

# ---------------------------------------------------------------------
# Supabase (servidor) — necesario para el muro `/muro`
# Si no configuras esto, la app sigue funcionando pero `/muro` y la
# opción de "compartir al muro" quedan deshabilitadas.
# ---------------------------------------------------------------------
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co

# Usa la "publishable key" (recomendado) o la "anon key" legacy.
# Esta clave es segura para enviar al cliente cuando RLS está activo.
SUPABASE_PUBLISHABLE_KEY=

# Opcional. Solo si necesitas bypass de RLS desde el servidor (no la
# expongas al cliente, no la prefijes con NEXT_PUBLIC_).
# SUPABASE_SERVICE_ROLE_KEY=

# Bucket donde se suben las imágenes compartidas. Debe ser público.
SUPABASE_WALL_BUCKET=wall-images

# ---------------------------------------------------------------------
# Generación con IA — opcional, elige UNO de los dos proveedores.
# Sin estas variables la app usa el render local en canvas como
# fallback (más simple, sin coste).
# ---------------------------------------------------------------------

# Opción A: Vercel AI Gateway (recomendada)
# AI_GATEWAY_API_KEY=
# AI_GATEWAY_IMAGE_MODEL=google/gemini-3-pro-image
# AI_GATEWAY_BASE_URL=https://ai-gateway.vercel.sh/v1

# Opción B: OpenAI directo
# OPENAI_API_KEY=
# OPENAI_IMAGE_MODEL=gpt-image-1
# OPENAI_IMAGE_SIZE=1024x1536
